# Core Supabase function runtime
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_PUBLISHABLE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# App URL used by OAuth callback final redirect (back to frontend)
APP_URL="http://localhost:5173"
FRONTEND_URL="http://localhost:5173"

# Optional explicit callback override. If empty, callback defaults to:
# ${SUPABASE_URL}/functions/v1/email-oauth-callback
EMAIL_OAUTH_CALLBACK_URL=""

# Google Workspace OAuth app
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# Microsoft 365 OAuth app
MICROSOFT_OAUTH_CLIENT_ID=""
MICROSOFT_OAUTH_CLIENT_SECRET=""

# Required AES-256 key for encrypting stored SMTP/OAuth credentials.
# Valid formats:
# - 32-byte base64 string (recommended, e.g. output of: openssl rand -base64 32)
# - 64-character hex string
# - 32-character raw string
EMAIL_CREDENTIALS_ENCRYPTION_KEY=""
